# Required environment variable for the EduInsight Next.js app.
#
# For local development: copy this file to .env.local and fill in the value.
# For Vercel deployment: add this variable in the Vercel project settings under
#   Project → Settings → Environment Variables → Add New
#
# The Convex backend is public/read-only — no auth token required.
NEXT_PUBLIC_CONVEX_URL=https://determined-mongoose-938.convex.cloud
